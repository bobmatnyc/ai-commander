#!/bin/bash
# Convenience wrapper for ai-commander
# Usage: ./ai daemon status, ./ai pair, ./ai tui, etc.

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Binary paths
RELEASE_BIN="./target/release/ai-commander"
DEBUG_BIN="./target/debug/ai-commander"

# Find the best available binary
if [[ -f "$RELEASE_BIN" ]]; then
    BIN="$RELEASE_BIN"
    BUILD_TYPE="release"
elif [[ -f "$DEBUG_BIN" ]]; then
    BIN="$DEBUG_BIN"
    BUILD_TYPE="debug"
else
    echo -e "${RED}Error: No ai-commander binary found${NC}"
    echo "Build with: cargo build --release -p ai-commander"
    exit 1
fi

# Show which binary we're using (helpful for debugging)
if [[ "${VERBOSE:-}" == "1" ]]; then
    echo -e "${YELLOW}Using: $BIN ($BUILD_TYPE)${NC}"
fi

# Handle help command to show both binary help and script usage
if [[ "${1:-}" == "help" || "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo -e "${GREEN}ai-commander convenience wrapper${NC}"
    echo ""
    echo "Usage:"
    echo "  ./ai daemon start    # Start daemon"
    echo "  ./ai daemon stop     # Stop daemon"
    echo "  ./ai daemon status   # Daemon status"
    echo "  ./ai daemon restart  # Restart daemon"
    echo "  ./ai pair           # Generate pairing code"
    echo "  ./ai tui            # Start TUI"
    echo "  ./ai list           # List projects"
    echo "  ./ai help           # Show this help"
    echo ""
    echo "Original ai-commander help:"
    exec "$BIN" --help
fi

# Handle common daemon shortcuts
case "${1:-}" in
    "start")
        exec "$BIN" daemon start
        ;;
    "stop")
        exec "$BIN" daemon stop
        ;;
    "status")
        exec "$BIN" daemon status
        ;;
    "restart")
        exec "$BIN" daemon restart
        ;;
    *)
        # Pass through all other commands
        exec "$BIN" "$@"
        ;;
esac
